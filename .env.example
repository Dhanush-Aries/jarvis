# Copy to .env and fill in whatever you have. Jarvis works with ZERO keys via Ollama.
# Provide any subset — the router auto-detects which providers are usable.

ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GROQ_API_KEY=
GEMINI_API_KEY=
MISTRAL_API_KEY=
DEEPSEEK_API_KEY=
OPENROUTER_API_KEY=
XAI_API_KEY=
TOGETHERAI_API_KEY=

# Local LLM (optional). Defaults shown.
OLLAMA_HOST=http://127.0.0.1:11434

# Where Jarvis stores its DB / plugins (optional).
# JARVIS_HOME=~/.jarvis
